{
	"name": "nodejs-falsework",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"packageManager": "pnpm@9.15.0",
	"scripts": {
		"dev": "nodemon src/index.ts",
		"dev:unwatch": "tsx src/index.ts",
		"build": "node ./config/esbuild.config.mts",
		"start": "node ./dist/index.js",
		"lint": "eslint && tsc --noEmit",
		"format": "prettier --write .",
		"prepare": "simple-git-hooks"
	},
	"devDependencies": {
		"@types/node": "^25.9.3",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"jiti": "^2.7.0",
		"nodemon": "^3.1.14",
		"prettier": "^3.8.4",
		"simple-git-hooks": "^2.13.1",
		"ts-node": "^10.9.2",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1"
	},
	"dependencies": {
		"dotenv": "^17.2.3"
	},
	"simple-git-hooks": {
		"pre-commit": "npm run lint && npm run format",
		"pre-push": "npm run format"
	},
	"engines": {
		"node": ">=22.13.0",
		"pnpm": ">=9.15.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/XiaoMing0000/nodejs-falsework.git"
	},
	"keywords": [],
	"bugs": {
		"url": "https://github.com/XiaoMing0000/nodejs-falsework/issues"
	},
	"homepage": "https://github.com/XiaoMing0000/nodejs-falseworkCode#readme",
	"author": "xiaoming0000",
	"license": "MIT"
}
